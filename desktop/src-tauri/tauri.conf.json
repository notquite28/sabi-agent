{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sabi Agent",
  "version": "0.1.0",
  "identifier": "dev.sabi.agent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Sabi Agent",
        "width": 1100,
        "height": 760,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
